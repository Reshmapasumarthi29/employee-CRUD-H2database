<configuration>

    <appender name="CONSOLE"
              class="ch.qos.logback.core.ConsoleAppender">

        <encoder>
            <pattern>%d{HH:mm:ss} [%level] %logger - %msg%n</pattern>
        </encoder>

    </appender>

    <appender name="EMPLOYEESERVICE_FILE"
              class="ch.qos.logback.core.FileAppender">

        <file>logs/employeeService.log</file>

        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%level] %logger - %msg%n</pattern>
        </encoder>

    </appender>

    <logger name="com.example.employee.service"
            level="INFO"
            additivity="false">

        <appender-ref ref="EMPLOYEESERVICE_FILE"/>

    </logger>

    <root level="ERROR">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>